{
  "manifest_version": 3,
  "name": "PlexBoxd",
  "version": "1.1",
  "description": "Check Plex server availability for movies on Letterboxd",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "identity",
    "windows",
    "cookies"
  ],
  "host_permissions": [
    "https://letterboxd.com/*",
    "https://plex.tv/*",
    "https://app.plex.tv/*",
    "https://*.plex.tv/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://letterboxd.com/film/*"],
      "js": ["content-script.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings.html",
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
} 